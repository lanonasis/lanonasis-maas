{
  "name": "@lanonasis/memory-service-maas",
  "version": "1.2.0-dev",
  "description": "[DEVELOPMENT] Enterprise Memory as a Service (MaaS) with API Key Management and MCP Integration",
  "main": "dist/server.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:conformance": "jest --testPathPattern=conformance --verbose",
    "test:conformance:discovery": "jest --testPathPattern=conformance/discovery",
    "test:conformance:auth": "jest --testPathPattern=conformance/auth-headers",
    "test:all": "npm run test && npm run test:conformance",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "validate:env": "tsx scripts/validate-env.ts",
    "docker:build": "docker build -t lanonasis-maas .",
    "docker:run": "docker run -p 3000:3000 lanonasis-maas",
    "docker:push": "docker push lanonasis-maas",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "deploy": "./scripts/deploy.sh deploy",
    "deploy:staging": "./scripts/deploy.sh deploy --env staging",
    "deploy:production": "./scripts/deploy.sh deploy --env production",
    "publish:all": "./scripts/deploy.sh publish-sdk && ./scripts/deploy.sh publish-cli",
    "publish:sdk": "./scripts/deploy.sh publish-sdk",
    "publish:cli": "./scripts/deploy.sh publish-cli",
    "build:all": "./scripts/deploy.sh build",
    "clean": "./scripts/deploy.sh clean",
    "workspace:install": "npm ci && npm ci --prefix cli && npm ci --prefix packages/lanonasis-sdk",
    "workspace:build": "npm run build && npm run build --prefix cli && npm run build --prefix packages/lanonasis-sdk",
    "workspace:test": "npm run test && npm run test --prefix packages/lanonasis-sdk",
    "workspace:lint": "npm run lint && npm run lint --prefix cli && npm run lint --prefix packages/lanonasis-sdk"
  },
  "keywords": [
    "memory",
    "ai",
    "microservice",
    "vector-search",
    "enterprise",
    "api-keys",
    "secrets",
    "mcp",
    "security",
    "maas"
  ],
  "author": "Seye Derick",
  "license": "MIT",
  "dependencies": {
    "@genkit-ai/mcp": "^1.22.0",
    "@netlify/functions": "^2.8.2",
    "@supabase/supabase-js": "^2.80.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "openai": "^4.104.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "redis": "^4.7.1",
    "serverless-http": "^3.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "winston": "^3.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
