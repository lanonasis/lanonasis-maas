{
  "name": "@lanonasis/memory-service-maas",
  "version": "1.2.0-dev",
  "description": "[DEVELOPMENT] Enterprise Memory as a Service (MaaS) with API Key Management and MCP Integration",
  "main": "dist/server.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:cli": "cd cli && bun run test",
    "test:mcp-core": "jest --config apps/mcp-core/jest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage && jest --config apps/mcp-core/jest.config.ts --coverage",
    "test:conformance": "vitest run --config vitest.config.ts tests/conformance",
    "test:conformance:discovery": "vitest run --config vitest.config.ts tests/conformance/discovery.test.ts",
    "test:conformance:auth": "vitest run --config vitest.config.ts tests/conformance/auth-headers.test.ts",
    "test:all": "bun run test && bun run test:cli",
    "lint": "bun x eslint src/**/*.ts",
    "lint:fix": "bun x eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "validate:env": "tsx scripts/validate-env.ts",
    "docker:build": "docker build -t lanonasis-maas .",
    "docker:run": "docker run -p 3000:3000 lanonasis-maas",
    "docker:push": "docker push lanonasis-maas",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "deploy": "./scripts/deploy.sh deploy",
    "deploy:staging": "./scripts/deploy.sh deploy --env staging",
    "deploy:production": "./scripts/deploy.sh deploy --env production",
    "publish:all": "./scripts/deploy.sh publish-sdk && ./scripts/deploy.sh publish-cli",
    "publish:sdk": "./scripts/deploy.sh publish-sdk",
    "publish:cli": "./scripts/deploy.sh publish-cli",
    "build:all": "./scripts/deploy.sh build",
    "clean": "./scripts/deploy.sh clean",
    "workspace:install": "npm ci && npm ci --prefix cli && npm ci --prefix packages/lanonasis-sdk",
    "workspace:build": "npm run build && npm run build --prefix cli && npm run build --prefix packages/lanonasis-sdk",
    "workspace:test": "npm run test && npm run test:cli && npm run test --prefix packages/lanonasis-sdk",
    "workspace:lint": "npm run lint && npm run lint --prefix cli && npm run lint --prefix packages/lanonasis-sdk",
    "package:claude-memory:install": "npm install --prefix packages/claude-memory",
    "package:claude-memory:build": "npm run build --prefix packages/claude-memory",
    "package:claude-memory:test": "npm run test --prefix packages/claude-memory",
    "package:claude-memory:typecheck": "npm run typecheck --prefix packages/claude-memory"
  },
  "keywords": [
    "memory",
    "ai",
    "microservice",
    "vector-search",
    "enterprise",
    "api-keys",
    "secrets",
    "mcp",
    "security",
    "maas"
  ],
  "author": "Seye Derick",
  "license": "MIT",
  "dependencies": {
    "@genkit-ai/mcp": "^1.25.0",
    "@lanonasis/oauth-client": "npm:@lanonasis/oauth-client@2.0.4",
    "@lanonasis/security-sdk": "^1.0.3",
    "@netlify/functions": "^2.8.2",
    "@supabase/supabase-js": "^2.56.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^2.7.0",
    "openai": "^4.76.1",
    "react": "19.2.1",
    "react-dom": "19.2.0",
    "redis": "^4.7.0",
    "serverless-http": "^3.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@jest/globals": "^30.2.0",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "anymatch": {
      "picomatch": "^2.3.2"
    },
    "micromatch": {
      "picomatch": "^2.3.2"
    }
  }
}
