{
  "name": "@lanonasis/memory-service-maas",
  "version": "1.2.0-dev",
  "description": "[DEVELOPMENT] Enterprise Memory as a Service (MaaS) with API Key Management and MCP Integration",
  "main": "dist/server.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:mcp-core": "jest --config apps/mcp-core/jest.config.ts",
    "test:coverage": "jest --coverage && jest --config apps/mcp-core/jest.config.ts --coverage",
    "test:conformance": "jest --testPathPattern=conformance --verbose",
    "test:conformance:discovery": "jest --testPathPattern=conformance/discovery",
    "test:conformance:auth": "jest --testPathPattern=conformance/auth-headers",
    "test:all": "npm run test && npm run test:conformance",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "validate:env": "tsx scripts/validate-env.ts",
    "docker:build": "docker build -t lanonasis-maas .",
    "docker:run": "docker run -p 3000:3000 lanonasis-maas",
    "docker:push": "docker push lanonasis-maas",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "deploy": "./scripts/deploy.sh deploy",
    "deploy:staging": "./scripts/deploy.sh deploy --env staging",
    "deploy:production": "./scripts/deploy.sh deploy --env production",
    "publish:all": "./scripts/deploy.sh publish-sdk && ./scripts/deploy.sh publish-cli",
    "publish:sdk": "./scripts/deploy.sh publish-sdk",
    "publish:cli": "./scripts/deploy.sh publish-cli",
    "build:all": "./scripts/deploy.sh build",
    "clean": "./scripts/deploy.sh clean",
    "workspace:install": "npm ci && npm ci --prefix cli && npm ci --prefix packages/lanonasis-sdk",
    "workspace:build": "npm run build && npm run build --prefix cli && npm run build --prefix packages/lanonasis-sdk",
    "workspace:test": "npm run test && npm run test --prefix packages/lanonasis-sdk",
    "workspace:lint": "npm run lint && npm run lint --prefix cli && npm run lint --prefix packages/lanonasis-sdk",
    "package:claude-memory:install": "npm install --prefix packages/claude-memory",
    "package:claude-memory:build": "npm run build --prefix packages/claude-memory",
    "package:claude-memory:test": "npm run test --prefix packages/claude-memory",
    "package:claude-memory:typecheck": "npm run typecheck --prefix packages/claude-memory"
  },
  "keywords": [
    "memory",
    "ai",
    "microservice",
    "vector-search",
    "enterprise",
    "api-keys",
    "secrets",
    "mcp",
    "security",
    "maas"
  ],
  "author": "Seye Derick",
  "license": "MIT",
  "dependencies": {
    "@genkit-ai/mcp": "^1.32.0",
    "@lanonasis/oauth-client": "npm:@lanonasis/oauth-client@2.0.4",
    "@lanonasis/security-sdk": "^1.0.5",
    "@netlify/functions": "^5.2.0",
    "@supabase/supabase-js": "^2.104.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^3.3.2",
    "openai": "^6.34.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "redis": "^5.12.1",
    "serverless-http": "^4.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "anymatch": {
      "picomatch": "^2.3.2"
    },
    "micromatch": {
      "picomatch": "^2.3.2"
    }
  }
}
