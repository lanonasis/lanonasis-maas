{
  "name": "@lanonasis/recall-forge",
  "version": "1.0.0",
  "description": "RecallForge \u2014 secret-safe memory and context engine plugin for OpenClaw. Fills both memory and contextEngine slots with tiered semantic recall, 30+ pattern credential redaction, and prompt injection protection.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./extraction": "./dist/extraction/index.js"
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "dist/",
    "openclaw.plugin.json",
    "SETUP.md",
    "setup/"
  ],
  "dependencies": {
    "undici": "^7.24.5"
  },
  "peerDependencies": {
    "openclaw": "latest"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run",
    "verify:release": "npm run typecheck && npm run test && npm run build && npm run pack:dry-run",
    "migrate": "node --import tsx migrate.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thefixer3x/lan-onasis-monorepo.git",
    "directory": "packages/openclaw-plugin"
  },
  "homepage": "https://github.com/thefixer3x/lan-onasis-monorepo/tree/main/packages/openclaw-plugin",
  "bugs": {
    "url": "https://github.com/thefixer3x/lan-onasis-monorepo/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "context-engine",
    "plugin",
    "lanonasis",
    "recall-forge",
    "neuro-forge",
    "semantic-search",
    "secret-protection",
    "credential-redaction",
    "privacy-first",
    "memory-safety",
    "context-protection"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "slots": [
      "memory",
      "contextEngine"
    ]
  }
}