{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "paths": {
      "openclaw/plugin-sdk": ["./plugin-sdk-stub.ts"],
      "openclaw/plugin-sdk/*": ["./plugin-sdk-stub.ts"]
    }
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}
