{
  "name": "@lanonasis/repl-cli",
  "version": "0.9.3",
  "type": "module",
  "description": "Intelligent REPL for LanOnasis Memory Service - Natural language interactive assistant with AI orchestration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "onasis-repl": "dist/index.js",
    "lrepl": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "repl",
    "cli",
    "memory",
    "lanonasis",
    "interactive",
    "memory-service",
    "maas",
    "ai",
    "knowledge-management",
    "semantic-search",
    "mcp",
    "model-context-protocol"
  ],
  "author": {
    "name": "Lanonasis Team",
    "email": "team@lanonasis.com",
    "url": "https://lanonasis.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thefixer3x/lan-onasis-monorepo.git",
    "directory": "apps/lanonasis-maas/packages/repl-cli"
  },
  "homepage": "https://docs.lanonasis.com/cli/repl",
  "bugs": {
    "url": "https://github.com/thefixer3x/lan-onasis-monorepo/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup && chmod +x dist/index.js",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "[ -d node_modules/chalk ] || bun install --no-save; vitest run",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@lanonasis/memory-client": "^2.2.0",
    "@lanonasis/oauth-client": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "inquirer": "^13.3.2",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "uuid": "^13.0.0",
    "vortexai-l0": "^1.2.2",
    "zod": "^4.3.6",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "minimatch": "^10.0.3",
    "qs": "^6.15.0",
    "@hono/node-server": "^1.19.10",
    "ajv": "^8.18.0",
    "rollup": "^4.59.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
