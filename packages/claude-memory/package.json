{
  "name": "@lanonasis/claude-memory",
  "version": "0.1.0",
  "description": "Cross-session semantic memory for Claude Code via LanOnasis MaaS",
  "type": "module",
  "author": {
    "name": "Lanonasis Team",
    "url": "https://lanonasis.com"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "claude-memory": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "prepublishOnly": "bun run build && bun run test",
    "install-hooks": "bun scripts/install-hooks.ts",
    "migrate": "echo 'migrate-sessions not yet implemented (Phase 7)' && exit 1",
    "drain": "echo 'drain-spool not yet implemented (Phase 6)' && exit 1"
  },
  "dependencies": {
    "undici": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lanonasis/lanonasis-maas.git",
    "directory": "packages/claude-memory"
  },
  "homepage": "https://github.com/lanonasis/lanonasis-maas/tree/main/packages/claude-memory#readme",
  "bugs": {
    "url": "https://github.com/lanonasis/lanonasis-maas/issues"
  },
  "files": [
    "dist",
    "hooks",
    "scripts",
    "enrichment",
    "skills",
    "spool.ts",
    "config.ts",
    "client.ts",
    "index.ts"
  ],
  "keywords": [
    "claude-code",
    "memory",
    "lanonasis",
    "semantic-search",
    "agent-memory"
  ]
}
